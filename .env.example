# ============================================================
# RustMasterTool Environment Example
# Copy this file to .env.local and fill values locally.
# Never commit .env.local.
# ============================================================

# ------------------------------------------------------------
# App
# ------------------------------------------------------------
NODE_ENV=development
APP_ENV=local
APP_URL=http://localhost:3000
API_URL=http://localhost:4000

# ------------------------------------------------------------
# Supabase Project
# ------------------------------------------------------------
SUPABASE_PROJECT_NAME=
SUPABASE_PROJECT_REF=
SUPABASE_REGION=
SUPABASE_URL=

# Client/public key.
# Safe only for browser usage when RLS policies are correct.
SUPABASE_ANON_KEY=
SUPABASE_PUBLISHABLE_KEY=

# Server-only keys.
# NEVER expose in browser.
# NEVER commit real values.
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_SECRET_KEY=

# ------------------------------------------------------------
# Database
# ------------------------------------------------------------
# Use this for app/backend runtime depending on final DB decision.
DATABASE_URL=

# Use this for migrations/direct schema operations.
DIRECT_URL=

# Optional explicit Supabase variants.
DATABASE_DIRECT_URL=
DATABASE_SESSION_POOLER_URL=
DATABASE_TRANSACTION_POOLER_URL=

# ------------------------------------------------------------
# Supabase Capability Notes
# Fill with yes/no/unknown locally for documentation.
# ------------------------------------------------------------
POSTGRES_VERSION=
SUPABASE_PLAN=
SUPABASE_STORAGE_ENABLED=
SUPABASE_REALTIME_ENABLED=

EXT_TIMESCALEDB=
EXT_PG_CRON=
EXT_PG_NET=
EXT_POSTGIS=
EXT_PG_PARTMAN=

# ------------------------------------------------------------
# BattleMetrics - later, do not fill unless explicitly needed
# ------------------------------------------------------------
BATTLEMETRICS_TOKEN=

# ------------------------------------------------------------
# RustMaps - later, do not fill unless explicitly needed
# ------------------------------------------------------------
RUSTMAPS_API_KEY=

# ------------------------------------------------------------
# Discord - later
# ------------------------------------------------------------
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_BOT_TOKEN=

# ------------------------------------------------------------
# Steam OpenID / Web API - later
# ------------------------------------------------------------
STEAM_WEB_API_KEY=

# ------------------------------------------------------------
# Stripe - later
# ------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ------------------------------------------------------------
# Internal Security - later
# ------------------------------------------------------------
JWT_SECRET=
ENCRYPTION_KEY=

# ------------------------------------------------------------
# Frontend Environment Variables
# ------------------------------------------------------------
# VITE_SUPABASE_URL and VITE_SUPABASE_ANON_KEY are safe for the frontend.
# Set these to your Staging or Production Supabase instance URLs.
# NEVER include service_role or SECRET keys here!
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Data Mode: 'fixture' or 'supabase'
# Set to 'supabase' to enable Cloud Watchlist persistence
VITE_DATA_MODE=fixture
